# ==========================================
# AMBIENTE & DIRETRIZES GERAIS
# ==========================================
ENVIRONMENT=development
GENERAL__BASEURL=http://localhost
USE_KUBERNETES_LOGS=false
SCRAPER_BASE_URL=https://exemplo-loja.com.br
DISCORD_WEBHOOK_URL=

# ==========================================
# SEGURANÇA & AUTH (Compartilhado C#)
# ==========================================
Jwt__Key=SUA_CHAVE_JWT_SUPER_SECRETA_DE_TESTES_32_BYTES
Google__ClientId=
Google__ClientSecret=
AES_MASTER_KEY=Y2hhdmVfbWVzdHJlX2Jhc2U2NF9hZXMyNTZfMzJieXRlcw== # 32 bytes Base64

# ==========================================
# PROVEDORES DE IA (Casado com o ecommerce-bot)
# ==========================================
Groq_API_KEY=gsk_sua_chave_groq_aqui
Deepseek_Api_Key=sk-sua_chave_deepseek_aqui

# ==========================================
# POSTGRESQL (Docker Compose Local)
# ==========================================
# Nota: Apontando para o hostname 'postgres' que é o DNS interno do compose
POSTGRES_TRANSACTION_CONNECTION_STRING="Host=postgres;Port=5432;Database=greg_company;Username=postgres;Password=postgres;Max Pool Size=40;Pooling=true;;SSL Mode=VerifyCA;SSL Root Certificate=/app/certs/supabase-ca.crt;"
POSTGRES_SESSION_CONNECTION_STRING="Host=postgres;Port=5432;Database=greg_company;Username=postgres;Password=postgres;Pooling=true;;SSL Mode=VerifyCA;SSL Root Certificate=/app/certs/supabase-ca.crt;"
POSTGRES_URI_PYTHON="postgresql+asyncpg://postgres.bvoxyxmettvzaejhftrq:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=verify-ca&sslrootcert=/app/certs/supabase-ca.crt"
POSTGRES_PASSWORD=postgres
POSTGRES_DB_NAME=greg_company

# ==========================================
# REDIS (Cache & Token Blocklist)
# ==========================================
ConnectionStrings__Redis=redis:6379
USE_REDIS=TRUE
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# RABBITMQ (Mensageria Local)
# ==========================================
# Ajustado para bater com o nome do serviço no Docker Compose
RabbitMQ__HostName=rabbitmq
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest

# ==========================================
# MERCADO PAGO & SENDGRID
# ==========================================
MercadoPago__AccessToken=
MercadoPago__PublicKey=
MercadoPago__WebhookSecret=
SendGrid__ApiKey=
SendGrid__FromEmail=
SendGrid__FromName=

# ==========================================
# ARMAZENAMENTO CLOUD (Supabase S3)
# ==========================================
Access_key_ID=
Secret_Access_key=
EndPoint_S3=

# ==========================================
# VARIÁVEIS DO FRONTEND (Vercel / Local)
# ==========================================
VITE_GENERAL__BASEURL=http://localhost
VITE_WS_URL=ws://localhost:8000/v1/demo/stream