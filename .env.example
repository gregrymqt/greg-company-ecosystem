# ==========================================
# SEGURANCA & AUTH (Compartilhado C#)
# ==========================================
Jwt__Key=

# OAuth Google
Google__ClientId=
Google__ClientSecret=

# ==========================================
# POSTGRESQL (Docker Compose local)
# ==========================================
POSTGRES_TRANSACTION_CONNECTION_STRING="Host=postgres;Port=5432;Database=greg_company;Username=postgres;Password=postgres;Max Pool Size=40;Pooling=true;"
POSTGRES_SESSION_CONNECTION_STRING="Host=postgres;Port=5432;Database=greg_company;Username=postgres;Password=postgres;Pooling=true;"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB_NAME=greg_company

# ==========================================
# REDIS (Cache & Token Blocklist)
# ==========================================
# ConnectionStrings__Redis é usado pelo C# (StackExchange.Redis) — hostname do serviço Docker
ConnectionStrings__Redis=redis:6379
USE_REDIS=TRUE
# REDIS_URL é usado pelo Python Bot (redis.asyncio) — formato URI completo
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# MERCADO PAGO (Gateway de Pagamento)
# ==========================================
MercadoPago__AccessToken=
MercadoPago__PublicKey=
MercadoPago__WebhookSecret=

# ==========================================
# SENDGRID (Email Transacional)
# ==========================================
SendGrid__ApiKey=
SendGrid__FromEmail=
SendGrid__FromName=

# Define de onde o MCP vai puxar os logs da infraestrutura
USE_KUBERNETES_LOGS=true

# URL base do backend
GENERAL__BASEURL=

# Credenciais do Supabase S3
Access_key_ID=
Secret_Access_key=
EndPoint_S3=

# Chaves das Apis
OPENAI_API_KEY=
Gemini_Api_Key=
AES_MASTER_KEY=

# Url base para Scraping
SCRAPER_BASE_URL=

# Url do webhook do discord
DISCORD_WEBHOOK_URL=

# Configuracoes do RabbitMQ
RabbitMQ__HostName=rabbitmq-service
RabbitMQ__Port=5672
RabbitMQ__UserName=user
RabbitMQ__Password=PASSWORD

# Variaveis para os frontends
VITE_GENERAL__BASEURL=
VITE_WS_URL=
